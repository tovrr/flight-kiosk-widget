# Copy to `.env.local` for local dev, or set these in your host (e.g. Vercel).
# All values are NEXT_PUBLIC_* → they are baked into the client bundle at build
# time. They are IDENTIFIERS, not secrets — never put an API token here.

# ── Travelpayouts (from your Travelpayouts dashboard) ────────────────────────
# Your partner marker / Partner ID. Leave the placeholder and bookings are NOT
# attributed to anyone; set your marker to start earning commissions.
NEXT_PUBLIC_TRAVELPAYOUTS_MARKER=000000
# Tracking source id of the "Flights Search Form" widget you generated.
NEXT_PUBLIC_TP_TRS=
# Optional: Travelpayouts "Drive" domain-verification script URL. Injected only
# if set. Get it from Travelpayouts → your website → verification snippet.
NEXT_PUBLIC_TP_DRIVE_SRC=
# Optional: host (no protocol) where the widget opens results — e.g. your White
# Label domain "flights.example.com". Empty → Aviasales default results page.
NEXT_PUBLIC_TP_SEARCH_URL=

# ── Brand ────────────────────────────────────────────────────────────────────
# The name renders in two tones: PREFIX (white) + SUFFIX (accent colour).
NEXT_PUBLIC_BRAND_PREFIX=Flight
NEXT_PUBLIC_BRAND_SUFFIX=Kiosk
# Widget colours (also edit app/globals.css to restyle the app chrome).
NEXT_PUBLIC_COLOR_PRIMARY=#0A0A0A
NEXT_PUBLIC_COLOR_ACCENT=#FFE800

# ── Behaviour ────────────────────────────────────────────────────────────────
# Canonical prod URL for the "continue on mobile" QR (falls back to current
# origin if empty).
NEXT_PUBLIC_SITE_URL=
# Optional full URL for the "Popular flights" button (hidden if empty).
NEXT_PUBLIC_RESULTS_URL=
# Widget language / currency.
NEXT_PUBLIC_LOCALE=en
NEXT_PUBLIC_CURRENCY=usd
# Idle delay (ms) before the kiosk resets to the attract screen.
NEXT_PUBLIC_IDLE_TIMEOUT_MS=90000
